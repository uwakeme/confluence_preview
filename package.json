{
  "name": "confluence-previewer",
  "displayName": "Confluence Previewer",
  "description": "Preview Confluence Storage Format (Source Editor XHTML) as it appears in Confluence",
  "icon": "image/icon.png",
  "version": "0.1.1",
  "publisher": "wake",
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/uwakeme/confluence_preview.git"
  },
  "bugs": {
    "url": "https://github.com/uwakeme/confluence_preview/issues"
  },
  "homepage": "https://github.com/uwakeme/confluence_preview#readme",
  "keywords": [
    "confluence",
    "preview",
    "jira",
    "storage-format",
    "wiki"
  ],
  "activationEvents": [
    "onLanguage:confluence",
    "onLanguage:html",
    "onCommand:confluence-previewer.openPreview"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "confluence",
        "aliases": [
          "Confluence",
          "Confluence Storage Format"
        ],
        "filenamePatterns": [
          "**/*.confluence",
          "**/*.cfl",
          "**/*.confluence-storage"
        ],
        "configuration": "./confluence.configuration.json"
      }
    ],
    "commands": [
      {
        "command": "confluence-previewer.openPreview",
        "title": "Confluence: Open Previewer",
        "category": "Confluence",
        "icon": "$(open-previewer)"
      },
      {
        "command": "confluence-previewer.copyHtml",
        "title": "Confluence: Copy Rendered HTML",
        "category": "Confluence"
      },
      {
        "command": "confluence-previewer.exportMarkdown",
        "title": "Confluence: Export to Markdown",
        "category": "Confluence"
      },
      {
        "command": "confluence-previewer.refresh",
        "title": "Confluence: Refresh Previewer",
        "category": "Confluence",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "confluence-previewer.openPreview",
          "when": "editorLangId == confluence || editorLangId == html",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "confluence-previewer.refresh",
          "when": "false"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "test": "node --test \"tests/*.test.mjs\"",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.75.0",
    "@vscode/test-cli": "^0.0.4",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "cheerio": "1.0.0-rc.12"
  }
}